# uv.lock is intentionally committed

# sensitive files
.env
creds.json

# terraform plan output (binary zip; may contain sensitive values).
# Only environments/*.tfvars are tracked; a top-level *.tfvars is almost
# always `terraform plan -out=...` output.
infra/terraform/*.tfvars
!infra/terraform/environments/*.tfvars
*.tfplan

# OS
.DS_Store

# artifacts of any sorts
dist/
build/
inputs/
outputs/
past_inputs/
*.json

# but do track Telegram payload fixtures used by the parser tests
!tests/fixtures/**/*.json